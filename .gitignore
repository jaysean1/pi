# Purpose: Keep generated Pi data and credentials out of Git.
# Not for: Hiding source configuration or extension code.
.DS_Store

# Pi credentials, backups, and live state
agent/auth.json
agent/settings.json.bak.*
agent/trust.json
agent/state/
agent/sessions/
cache/
memory.md
web-search.json

# Installed dependencies and local binaries
**/node_modules/
agent/bin/

# Runtime noise
*.log
*.lock

# Cursor / Pi Studio runtime
agent/cursor-model-cache.json
agent/session-footer-switcher-cache.json
agent/cursor-proxy.json
agent/cursor-config.json
agent/run-history.jsonl
pistudio-instances/
agent/extensions/kooky.ts

# Extension install / version state (regenerated at runtime)
agent/extensions/pi-codex-image-gen-install.json

# Build & runtime scratch products
agent/tmp/
agent/generated-images/

# Prompt suggester generated per-project seeds
agent/prompt-suggester/projects/

# Installed skills (pulled by pi at runtime)
agent/skills/
